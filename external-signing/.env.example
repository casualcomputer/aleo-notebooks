# Provable Delegated Proving Service credentials.
# Register a consumer at POST https://api.provable.com/consumers to get an API key + consumer ID.
# See ../dps-test/README.md for the one-time setup.
PROVABLE_API_KEY=
PROVABLE_CONSUMER_ID=

# Throwaway testnet private key. Generate with `npm run gen-account`.
# NEVER put a real wallet key here — this is a tutorial. The whole POINT of this
# tutorial is that the user's real key stays in their wallet, not in the dApp.
TESTNET_PRIVATE_KEY=
